<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.citizenwizard"
       name="Citizen Wizard"
       version="1.4.9"
       provider-name="ATZMFour">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.requests" />
        <import addon="script.module.six" />
        <import addon="script.kodi.android.update" optional="true" version="1.1.7" />
        <import addon="script.speedtester" optional="true" version="1.1.2" />
    </requires>

    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.service" library="startup.py" start="startup" />

    <extension point="xbmc.addon.metadata">
        <summary lang="en">Citizen Wizard</summary>
        <description lang="en">
            Citizen Wizard offers maintenance tools, backup and restore features,
            and automated Citizen Build installation.
        </description>

        <platform>all</platform>
        <reuselanguageinvoker>false</reuselanguageinvoker>

        <source>https://github.com/ATZMFour/Citizen-Wizard</source>

        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>

        <news>
1.4.9
 - Initial Citizen Wizard release
 - Updated for Kodi 21 Omega
 - Renamed from OpenWizard
        </news>

        <license>GPL-3.0-only</license>
    </extension>

</addon>